<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E0E0E0" />
        </shape>
    </item>
    <item
        android:bottom="20dp"
        android:left="60dp"
        android:right="60dp"
        android:top="20dp">
        <shape android:shape="rectangle">
            <solid android:color="#BCBCBC" />
        </shape>
    </item>
    <item
        android:bottom="40dp"
        android:left="40dp"
        android:right="40dp"
        android:top="40dp">
        <rotate
            android:fromDegrees="45"
            android:pivotX="50%"
            android:pivotY="50%"
            android:toDegrees="45">
            <shape android:shape="rectangle">
                <solid android:color="#BCBCBC" />
            </shape>
        </rotate>
    </item>
</layer-list>