<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <ImageView
        android:id="@+id/imageTeacherAvatar"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:contentDescription="Teacher avatar"
        android:src="@drawable/ic_avatar" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textTeacherName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#1A1A1A"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textTeacherTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#EA4243"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textTeacherRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#1A1A1A"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textTeacherStudents"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textTeacherExperience"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_teacher_stat_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textColor="#EA4243"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/textTeacherSpecialty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_teacher_stat_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textColor="#EA4243"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/buttonBookTeacher"
        android:layout_width="74dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_button_primary"
        android:text="Book"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />

</LinearLayout>


